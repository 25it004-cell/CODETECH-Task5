<!DOCTYPE html>
<html>
<head>
    <title>Travel Planning Portal</title>

    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, sans-serif;
        }

        body{
            background:#f0f8ff;
        }

        header{
            background:#0077b6;
            color:white;
            text-align:center;
            padding:20px;
        }

        .container{
            width:500px;
            margin:40px auto;
            background:white;
            padding:25px;
            border-radius:10px;
            box-shadow:0 0 10px rgba(0,0,0,0.2);
        }

        h2{
            text-align:center;
            margin-bottom:20px;
            color:#0077b6;
        }

        label{
            font-weight:bold;
        }

        input, select{
            width:100%;
            padding:10px;
            margin:8px 0 15px;
            border:1px solid #ccc;
            border-radius:5px;
        }

        button{
            width:100%;
            padding:12px;
            background:#28a745;
            color:white;
            border:none;
            border-radius:5px;
            font-size:16px;
            cursor:pointer;
        }

        button:hover{
            background:#218838;
        }

        #result{
            margin-top:20px;
            padding:15px;
            background:#e8f5e9;
            border-radius:5px;
            display:none;
        }
    </style>
</head>

<body>

<header>
    <h1>Travel Planning Portal</h1>
</header>

<div class="container">

    <h2>Plan Your Trip</h2>

    <label>Traveler Name</label>
    <input type="text" id="name" placeholder="Enter Name">

    <label>Destination</label>
    <select id="destination">
        <option>Ooty</option>
        <option>Kodaikanal</option>
        <option>Goa</option>
        <option>Kerala</option>
        <option>Manali</option>
    </select>

    <label>Number of Days</label>
    <input type="number" id="days" placeholder="Enter Days">

    <label>Budget Per Day (₹)</label>
    <input type="number" id="budget" placeholder="Enter Budget">

    <button onclick="planTrip()">Calculate Trip Cost</button>

    <div id="result"></div>

</div>

<script>
function planTrip()
{
    var name = document.getElementById("name").value;
    var destination = document.getElementById("destination").value;
    var days = document.getElementById("days").value;
    var budget = document.getElementById("budget").value;

    var total = days * budget;

    document.getElementById("result").style.display="block";
    document.getElementById("result").innerHTML =
        "<h3>Trip Summary</h3>" +
        "<p><b>Name:</b> " + name + "</p>" +
        "<p><b>Destination:</b> " + destination + "</p>" +
        "<p><b>Days:</b> " + days + "</p>" +
        "<p><b>Total Budget:</b> ₹" + total + "</p>";
}
</script>

</body>
</html>
